#: ../../source/index.rst:2
msgid "BurnBox's documentation"
msgstr "Documentación de BurnBox"

#: ../../source/index.rst:6
msgid ""
"BurnBox is an open source tool that lets you securely and anonymously "
"share files, host websites, and chat with friends using the Tor network."
msgstr ""
"BurnBox es una herramienta de código abierto que te permite compartir "
"archivos de forma segura y anónima, alojar sitios web y charlar con amigos "
"usando la red Tor."
